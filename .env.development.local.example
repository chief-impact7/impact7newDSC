# Vite dev 환경 전용 설정 (gitignored: .env.development.local)
# 사용법: 이 파일을 .env.development.local로 복사한 뒤 원하는 플래그의 주석(#)을 풀고 dev 서버 재시작
#
#   cp .env.development.local.example .env.development.local
#   npm run dev
#
# 두 옵션은 함께 켜도 되고 따로 켜도 됨. 옵션 없으면 production DB를 직격함(주의).

# ─────────────────────────────────────────────────────────────────────────────
# READ-ONLY 모드 (가장 간단한 안전장치)
# audit.js의 모든 Firestore write wrapper를 console.log로 stub.
# 화면 상단에 "🔒 READ-ONLY DEV MODE" 노란 배너 자동 표시.
# read는 정상 동작, write만 차단. UI 검증 / 화면 둘러보기에 적합.
# ─────────────────────────────────────────────────────────────────────────────
# VITE_READ_ONLY=true

# ─────────────────────────────────────────────────────────────────────────────
# Firebase Emulator 모드 (완전 격리)
# Firestore + Auth를 로컬 emulator에 연결.
# write도 정상 동작하지만 emulator로만 가서 production 영향 0.
# 사용 전: 별도 터미널에서 `npx firebase emulators:start --import=./emulator-data --export-on-exit`
# emulator UI: http://localhost:4000
# ─────────────────────────────────────────────────────────────────────────────
# VITE_USE_EMULATOR=true
