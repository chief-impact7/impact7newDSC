rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // 인증 헬퍼 (DB/DSC 앱용)
    // =========================================================================
    function isLoggedIn() {
      return request.auth != null;
    }

    function isAuthorized() {
      return isLoggedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@impact7\\.kr$');
    }

    function withinFieldLimit(max) {
      return request.resource.data.keys().size() <= max;
    }

    // =========================================================================
    // 인증 헬퍼 (Director 앱용)
    // =========================================================================
    function getUserRole() {
      return get(/databases/$(database)/documents/HR_users/$(request.auth.uid)).data.role;
    }
    function isOwner() { return isLoggedIn() && getUserRole() == 'owner'; }
    function isDirector() { return isLoggedIn() && getUserRole() in ['owner', 'principal']; }
    function isManager() { return isLoggedIn() && getUserRole() == 'manager'; }
    function isStaff() { return isLoggedIn() && getUserRole() == 'staff'; }
    function isShortTerm() { return isLoggedIn() && getUserRole() == 'shortterm'; }
    // AI 일괄 생성(비용 발생) 권한: director 등급 이상. isDirector는 'director' role을 포함하지 않으므로 별도 헬퍼.
    function canRunAiBatch() { return isLoggedIn() && getUserRole() in ['owner', 'principal', 'director']; }
    function canManagePermissions() {
      return isLoggedIn()
        && (isDirector()
            || get(/databases/$(database)/documents/HR_users/$(request.auth.uid)).data.permissions.canManagePermissions == true);
    }
    // 인원현황(학원 기밀): HR_users 권한 보유자만. HR_users 문서가 없으면 get() 실패 → 거부
    function hasPopulationStatsAccess() {
      return isLoggedIn()
        && (isDirector()
            || get(/databases/$(database)/documents/HR_users/$(request.auth.uid)).data.permissions.get('canViewPopulationStats', false) == true);
    }
    function isImpact7VerifiedEmail() {
      return isLoggedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@impact7\\.kr$');
    }

    // =========================================================================
    // 인증 헬퍼 (Exam 앱용) — exam_users/{uid}.role 기반.
    // exists() 가드 + data.get() 기본값: 문서 부재(프로비저닝 전/타 앱 직원)든
    // role 필드 부재든 평가 에러 없이 clean deny. HR_users(getUserRole)는
    // exam 교사가 문서를 안 가질 수 있어 역할 소스로 쓰지 않는다.
    // =========================================================================
    function examUserRole() {
      return exists(/databases/$(database)/documents/exam_users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/exam_users/$(request.auth.uid)).data.get('role', '')
        : '';
    }
    function isExamMember() { return isAuthorized() && examUserRole() in ['teacher', 'owner']; }
    function isExamOwner() { return isAuthorized() && examUserRole() == 'owner'; }

    // =========================================================================
    // [HR] 통합 staff 공개 온보딩·서명 토큰 검증 헬퍼 (다토큰)
    // Firestore rules는 컬렉션 경로를 변수화하지 못하므로 호출부에서 완성된 path를
    // 넘기고, exists()로 get()을 가드해 미존재 컬렉션 분기가 OR 평가를 깨지 않게 한다.
    // =========================================================================
    function hrOnboardingTokenValid(tokenPath) {
      return exists(tokenPath)
        && get(tokenPath).data.status == 'pending'
        && get(tokenPath).data.expiresAt > request.time;
    }
    // hrSigningTokenValid/hrSigningTokenForContract는 계약 서명이 서버 callable로 이전되며 제거됨.

    // =========================================================================
    // [공통] 학생 마스터 컬렉션
    // =========================================================================
    match /students/{docId} {

      function hasRequiredStudentFields() {
        let data = request.resource.data;
        // 비원생 신규 생성 허용 — status/phone/branch 없이도 create 가능
        return data.keys().hasAll(['name', 'enrollments'])
          && data.name is string
          && data.name.size() > 0
          && data.enrollments is list
          && (!data.keys().hasAny(['status']) || (
                data.status is string
                && data.status in ['등원예정', '재원', '실휴원', '가휴원', '퇴원', '상담', '종강']
             ))
          && (!data.keys().hasAny(['parent_phone_1']) || (
                data.parent_phone_1 is string
                && data.parent_phone_1.size() > 0
             ))
          && (!data.keys().hasAny(['acquisition_source']) || (
                data.acquisition_source is string
                && data.acquisition_source.size() > 0
                && data.acquisition_source.size() <= 50
             ))
          && (!data.keys().hasAny(['acquisition_branch']) || (
                data.acquisition_branch is string
                && data.acquisition_branch in ['2단지', '10단지']
             ))
          && (!data.keys().hasAny(['branch']) || data.branch is string);
      }

      // 클라이언트가 생성/수정할 수 있는 필드 목록. 서버 전용 필드(message_consent —
      // promoConsent/optOut080Sync가 admin으로 기록)는 여기 넣지 않는다 — update가 diff 기반이라
      // 서버가 학생 문서에 새 필드를 추가해도 기존 문서의 클라 편집이 깨지지 않고, 클라는
      // 서버 전용 필드를 위조할 수 없다.
      function clientStudentFields() {
        return [
          'name', 'level', 'grade',
          'school_elementary', 'school_middle', 'school_high', 'school_level_grade',
          'student_phone', 'parent_phone_1', 'parent_phone_2', 'other_phone',
          'acquisition_source', 'acquisition_branch',
          'guardian_name_1', 'guardian_name_2',
          'branch', 'status', 'status2', 'enrollments',
          'enrollments_cleared_at', 'enrollments_cleared_by',
          'pause_start_date', 'pause_end_date',
          'scheduled_leave_status', 'pre_withdrawal_status',
          'day', 'class_type', 'level_code', 'level_symbol', 'class_number',
          'start_date', 'special_start_date', 'special_end_date',
          'first_registered',
          'has_memo', 'memo',
          'return_consult_done', 'return_consult_note',
          'return_consult_done_by', 'return_consult_done_at',
          'updated_at', 'updated_by', 'withdrawal_date',
          'status_changed_at', 'status_changed_by', 'status_previous',
          'nameNormalized', 'studentNumber', 'studentNumberSource', 'studentNumberIssuedAt',
          'studentNumberHistory',
          'school_history',
          'message_recipient_settings',
          'parent_message_recipient_fields'
        ];
      }
      // create 필드 상한은 clientStudentFields가 단일 소스다.

      // DB/DSC: 읽기+쓰기, Director: 읽기만
      allow read: if isAuthorized();

      // enrollment↔status 정합성: enrollment 보유 시 재원 계열 status만 (상담/퇴원/종강+enrollment 차단)
      function enrollmentStatusConsistent() {
        return request.resource.data.get('enrollments', []).size() == 0
          || request.resource.data.get('status', '') in ['재원', '등원예정', '실휴원', '가휴원'];
      }

      allow create: if isAuthorized()
        && hasRequiredStudentFields()
        && request.resource.data.keys().hasOnly(clientStudentFields())
        && enrollmentStatusConsistent();

      // update는 클라가 실제 변경한 키만 검증(diff.affectedKeys) — 문서 전체 키를 hasOnly로
      // 검사하던 방식은 서버가 admin으로 새 필드를 기록할 때마다 그 학생의 모든 클라 편집을
      // 조용히 거부했다(2026-05-30 school_*, 2026-07-04 message_consent 사고의 근본 해소).
      allow update: if isAuthorized()
        && hasRequiredStudentFields()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(clientStudentFields())
        && (!resource.data.keys().hasAny(['acquisition_source'])
          || resource.data.acquisition_source.size() == 0
          || request.resource.data.acquisition_source == resource.data.acquisition_source)
        && (!resource.data.keys().hasAny(['acquisition_branch'])
          || resource.data.acquisition_branch.size() == 0
          || request.resource.data.acquisition_branch == resource.data.acquisition_branch)
        && (!resource.data.keys().hasAny(['status']) || request.resource.data.keys().hasAny(['status']))
        && enrollmentStatusConsistent();

      allow delete: if false;  // 삭제 차단 — soft-delete(status='퇴원')로 대체

      // 메모 서브컬렉션
      match /memos/{memoId} {

        function hasRequiredMemoFields() {
          let data = request.resource.data;
          return data.keys().hasAll(['text', 'author', 'created_at'])
            && data.text is string
            && data.text.size() > 0
            && data.text.size() <= 2000
            && data.author is string;
        }

        function hasOnlyAllowedMemoFields() {
          return request.resource.data.keys().hasOnly(['text', 'author', 'created_at']);
        }

        allow read: if isAuthorized();

        allow create: if isAuthorized()
          && hasRequiredMemoFields()
          && hasOnlyAllowedMemoFields();

        allow update: if false;
        allow delete: if isAuthorized();
      }
    }

    // =========================================================================
    // [공통] 이력 로그: 읽기 + 생성만, 수정/삭제 불가
    // =========================================================================
    match /history_logs/{logId} {

      function hasRequiredLogFields() {
        let data = request.resource.data;
        return data.keys().hasAll(['doc_id', 'change_type', 'before', 'after', 'google_login_id', 'timestamp'])
          && data.doc_id is string
          && data.doc_id.size() > 0
          && data.change_type is string
          && data.change_type in ['ENROLL', 'UPDATE', 'WITHDRAW', 'DELETE', 'RETURN', 'STATUS_CHANGE', 'RESTORE', 'LR_AMEND', 'PROMOTION']
          && data.before is string
          && data.after is string
          && data.google_login_id is string
          && data.google_login_id.size() > 0;
      }

      function hasOnlyAllowedLogFields() {
        return request.resource.data.keys().hasOnly([
          'doc_id', 'change_type', 'before', 'after', 'google_login_id', 'timestamp',
          'updated_by', 'updated_at'
        ]);
      }

      allow read: if isAuthorized();

      allow create: if isAuthorized()
        && hasRequiredLogFields()
        && hasOnlyAllowedLogFields();

      allow update, delete: if false;
    }

    // =========================================================================
    // [DB/DSC] 사용자 역할: 자기 문서만 읽기, 생성/수정/삭제는 콘솔에서만
    // =========================================================================
    match /users/{userEmail} {
      allow read: if isAuthorized()
        && request.auth.token.email == userEmail;

      allow create, update, delete: if false;
    }

    // =========================================================================
    // [Exam] 사용자 프로필 (UID 기반)
    // =========================================================================
    match /exam_users/{userId} {
      // 외부(비 impact7) 도메인 차단 — isLoggedIn()이 아닌 도메인 검증.
      allow read: if isAuthorized();

      // 자기 문서 신규 생성(exam 첫 로그인 프로비저닝): 기본 등급 'teacher'만 — owner 자가 부여 차단.
      allow create: if isAuthorized()
        && request.auth.uid == userId
        && request.resource.data.role == 'teacher';

      // 자기 문서 수정: role 불변(권한 상승 차단). 표시명·deptIds 등만 변경 가능.
      allow update: if isAuthorized()
        && request.auth.uid == userId
        && request.resource.data.role == resource.data.role;

      // owner: 타인 포함 전체 관리(역할 부여·회수는 owner 전용). role 오타/누락 문서가
      // 생기면 그 계정의 exam write 전체가 잠기므로 스키마를 강제한다.
      allow create, update: if isExamOwner()
        && request.resource.data.get('role', '') in ['teacher', 'owner'];
      allow delete: if isExamOwner();
    }

    // =========================================================================
    // [DB] 일별 통계 스냅샷
    // =========================================================================
    match /daily_stats/{dateId} {

      // 전체 인원현황 스냅샷 — canViewPopulationStats 보유자만 (DB 앱 자동 생성도 권한자 로그인 시에만 동작)
      allow read: if isAuthorized() && hasPopulationStatsAccess();

      allow create: if isAuthorized()
        && hasPopulationStatsAccess()
        && request.resource.data.keys().hasAll(['date', 'generated_at', 'generated_by', 'total', 'active_total', 'by_status'])
        && request.resource.data.keys().hasOnly([
             'date', 'generated_at', 'generated_by', 'total', 'active_total',
             'by_status', 'by_branch', 'by_level', 'by_class_code',
             'by_status_branch', 'by_level_symbol_branch'
           ]);

      allow update, delete: if false;
    }

    // =========================================================================
    // [DSC] Temp Class Overrides (임시 타반수업)
    // =========================================================================
    match /temp_class_overrides/{docId} {

      function hasOnlyAllowedTempClassOverrideFields() {
        return request.resource.data.keys().hasOnly([
          'student_id', 'student_name', 'original_class_code', 'target_class_code',
          'target_start_time', 'override_date', 'reason', 'status',
          'created_by', 'created_at', 'updated_by', 'updated_at'
        ]);
      }

      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && hasOnlyAllowedTempClassOverrideFields()
        && request.resource.data.status is string
        && request.resource.data.status in ['active', 'cancelled']
        && withinFieldLimit(15);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DSC] Daily Records (일일 기록)
    // =========================================================================
    match /daily_records/{docId} {
      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && withinFieldLimit(30);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DSC] 미등원 안내 발송 멱등 기록 — 로그북 '미도착(연락)' 발송 상태 표시용.
    // write는 서버(sendAbsenceNotice callable / absenceNoticeSweeper)만, 클라는 read만.
    // =========================================================================
    match /absence_notices/{docId} {
      allow read: if isAuthorized();
    }

    // =========================================================================
    // [DSC] Retake Schedule (재시/보충 일정)
    // =========================================================================
    match /retake_schedule/{docId} {
      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && request.resource.data.keys().hasOnly([
          'student_id', 'student_name', 'branch', 'class_code',
          'type', 'domain', 'subject', 'title', 'original_date',
          'scheduled_date', 'scheduled_time', 'result_score',
          'status', 'created_by', 'created_at',
          'completed_by', 'completed_at', 'cancelled_by', 'cancelled_at',
          'updated_by', 'updated_at'
        ])
        && withinFieldLimit(25);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DSC] HW Fail Tasks (2차 미통과 밀린 숙제)
    // =========================================================================
    match /hw_fail_tasks/{docId} {
      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && request.resource.data.keys().hasOnly([
          'student_id', 'student_name', 'domain', 'type', 'source',
          'source_date', 'scheduled_date', 'scheduled_time',
          'alt_hw', 'handler', 'status', 'created_by', 'created_at',
          'completed_by', 'completed_at', 'cancelled_by', 'cancelled_at', 'branch',
          'reschedule_history', 'updated_by', 'updated_at'
        ])
        && request.resource.data.status is string
        && request.resource.data.status in ['pending', '완료', '취소', '기타']
        && withinFieldLimit(20);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DSC] Test Fail Tasks (2차 미통과 밀린 테스트)
    // =========================================================================
    match /test_fail_tasks/{docId} {
      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && request.resource.data.keys().hasOnly([
          'student_id', 'student_name', 'domain', 'type', 'source',
          'source_date', 'scheduled_date', 'scheduled_time',
          'alt_hw', 'handler', 'status', 'created_by', 'created_at',
          'completed_by', 'completed_at', 'cancelled_by', 'cancelled_at', 'branch',
          'reschedule_history', 'updated_by', 'updated_at'
        ])
        && request.resource.data.status is string
        && request.resource.data.status in ['pending', '완료', '취소', '기타']
        && withinFieldLimit(20);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [Board] 칸반 카드 — impact7board SPA. board: ops(학원 업무)/students(학생 관리)/
    // personal(내 업무 — 클라이언트 표시 필터로 작성자 전용, 서버 강제 없음: 신뢰 직원 전제).
    // 단일 컬렉션, column = 보드별 상태. update로 board 변경 허용(보드 간 이동).
    // 삭제는 작성자 본인만, 그 외는 archived 플래그로 보관.
    // =========================================================================
    match /board_cards/{cardId} {

      function hasOnlyAllowedBoardCardCreateFields() {
        return request.resource.data.keys().hasOnly([
          'board', 'column', 'order', 'title', 'description',
          'student_id', 'student_name', 'branch', 'assignees', 'due_date', 'labels',
          'due_time', 'location', 'priority', 'pinned', 'recurrence',
          'checklist', 'links', 'attachments', 'parent_id', 'related', 'archived',
          'created_by', 'created_at', 'updated_by', 'updated_at',
          'completed_by', 'completed_at',
          'round', 'enrolled', 'exec_status'
        ]);
      }

      function hasOnlyAllowedBoardCardUpdateFields() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'board', 'column', 'order', 'title', 'description',
          'student_id', 'student_name', 'branch', 'assignees', 'due_date', 'labels',
          'due_time', 'location', 'priority', 'pinned', 'recurrence',
          'checklist', 'links', 'attachments', 'parent_id', 'related', 'archived',
          'updated_by', 'updated_at', 'completed_by', 'completed_at',
          'round', 'enrolled', 'exec_status',
          'last_comment_at', 'last_comment_by', 'comment_count'
        ]);
      }

      // sunindex(수능인덱스) 컬럼은 board_sections 문서 id(동적)라 열거 불가 — 비어있지 않은 문자열만 요구.
      function boardCardColumnValid() {
        return (request.resource.data.board == 'ops'
              && request.resource.data.column in ['ideas', 'todo', 'doing', 'review', 'done'])
          || (request.resource.data.board == 'students'
              && request.resource.data.column in ['intake', 'placement', 'enrolling', 'followup', 'done'])
          || (request.resource.data.board == 'personal'
              && request.resource.data.column in ['todo', 'doing', 'done'])
          || (request.resource.data.board == 'sunindex'
              && request.resource.data.column is string
              && request.resource.data.column != '');
      }

      allow read: if isAuthorized();

      allow create: if isAuthorized()
        && hasOnlyAllowedBoardCardCreateFields()
        && request.resource.data.board in ['ops', 'students', 'personal', 'sunindex']
        && request.resource.data.title is string
        && boardCardColumnValid();

      allow update: if isAuthorized()
        && hasOnlyAllowedBoardCardUpdateFields()
        && boardCardColumnValid();

      // 영구 삭제는 작성자 본인만 — created_by는 auditAdd가 정규화(@impact7.kr) 이메일로 찍는다.
      // 레거시(created_by 없음) 카드는 삭제 불가, 보관만.
      allow delete: if isAuthorized()
        && resource.data.get('created_by', '') == request.auth.token.email;
    }

    // [Board] 카드 댓글 — board_cards 서브컬렉션(impact7board CardModal). 수정 개념 없음(update 불허).
    // 삭제는 신뢰 직원 전제로 서명 사용자 전체 허용 — 본인 댓글 삭제 + 카드 영구 삭제 시
    // writeBatch 일괄 정리(카드 작성자가 타인 댓글도 지움) 둘 다 이 규칙 하나로 커버.
    match /board_cards/{cardId}/comments/{commentId} {
      allow read: if isAuthorized();

      allow create: if isAuthorized()
        && request.resource.data.keys().hasOnly([
          'text', 'parent_id', 'created_by', 'created_at', 'updated_by', 'updated_at'
        ])
        && request.resource.data.text is string
        && request.resource.data.text != '';

      allow delete: if isAuthorized();
    }

    // [Board] 댓글 읽음 상태 — 사용자당 문서 1개(board_comment_reads/{email}), reads 맵에 cardId→읽은 시각.
    // 본인 문서만 읽고 쓴다(email == 토큰 이메일). 삭제 개념 없음.
    match /board_comment_reads/{email} {
      allow read: if isAuthorized() && email == request.auth.token.email;

      allow create, update: if isAuthorized()
        && email == request.auth.token.email
        && request.resource.data.keys().hasOnly([
          'reads', 'created_by', 'created_at', 'updated_by', 'updated_at'
        ])
        && request.resource.data.reads is map;
    }

    // [Board] HR 직원현황의 안전 명부 미러 — 이름·이메일·부서·재직 여부만 서버가 동기화한다.
    match /staff_directory/{staffId} {
      allow read: if isAuthorized();
      allow write: if false;
    }

    // [Board] 주간 AI 브리핑 — 서버(Functions callable)만 생성, 클라이언트는 읽기만.
    match /board_briefings/{weekKey} {
      allow read: if isAuthorized();
      allow write: if false;
    }

    // [Board] 수능인덱스 보드 섹션 — 날짜+시간 동적 컬럼(impact7board /board/?view=sunindex).
    // 문서 id가 board_cards.column 값이 된다. 수정 개념 없음(만들고 지우기만) — update 불허.
    match /board_sections/{sectionId} {
      allow read: if isAuthorized();

      allow create: if isAuthorized()
        && request.resource.data.keys().hasOnly([
          'board', 'date', 'time',
          'created_by', 'created_at', 'updated_by', 'updated_at'
        ])
        && request.resource.data.board == 'sunindex'
        && request.resource.data.date is string
        && request.resource.data.time is string;

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DSC] User Settings (역할 설정)
    // =========================================================================
    match /user_settings/{email} {

      function hasOnlyAllowedUserSettingsFields() {
        return request.resource.data.keys().hasOnly([
          'role', 'updated_by', 'updated_at'
        ]);
      }

      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && request.auth.token.email == email
        && hasOnlyAllowedUserSettingsFields()
        && withinFieldLimit(10);

      allow delete: if isAuthorized()
        && request.auth.token.email == email;
    }

    // =========================================================================
    // [DSC] Role Memos (역할별 메모)
    // =========================================================================
    match /role_memos/{docId} {

      function hasOnlyAllowedRoleMemoFields() {
        return request.resource.data.keys().hasOnly([
          'type', 'student_id', 'student_name', 'content',
          'sender_email', 'sender_role', 'target_roles',
          'date', 'pinned', 'read_by', 'created_at', 'updated_by', 'updated_at'
        ]);
      }

      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && hasOnlyAllowedRoleMemoFields()
        && withinFieldLimit(15);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DSC] Class Settings (반별 설정: 영역, 테스트 등)
    // =========================================================================
    match /class_settings/{classCode} {

      function hasOnlyAllowedClassSettingsFields() {
        return request.resource.data.keys().hasOnly([
          'domains', 'test_sections', 'teacher', 'sub_teacher',
          'default_time', 'default_time_updated_by', 'default_time_updated_at',
          'naesin_start', 'naesin_end', 'schedule',
          'free_schedule', 'free_start', 'free_end',
          'special_start', 'special_end',
          'class_type', 'fee_type', 'updated_at', 'updated_by',
          'default_days'
        ]);
      }

      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && hasOnlyAllowedClassSettingsFields()
        && withinFieldLimit(20);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DSC] 자동화 설정 (AI 일괄 생성 등) — director 등급 이상만. 비용 발생 작업 통제.
    // 클라(설정 UI)는 enabled/interval/run_day/run_hour/skip_within_days만 patch한다.
    // last_run_*/running/progress_* 는 Cloud Function이 admin SDK로 갱신(rules 우회)하지만,
    // merge update 시 request.resource.data에 기존 함수 필드가 포함되므로 hasOnly 통과를 위해 허용 목록에 둔다.
    // =========================================================================
    match /automation_settings/{docId} {

      function hasOnlyAutomationFields() {
        return request.resource.data.keys().hasOnly([
          'enabled', 'interval', 'run_day', 'run_hour', 'skip_within_days',
          'updated_by', 'updated_at',
          'last_run_at', 'last_run_status', 'last_run_generated', 'last_run_skipped',
          'last_run_total_tokens', 'last_run_cost_usd',
          'progress_done', 'progress_total',
          'batch_active', 'chunk_lock', 'run_started_at', 'run_pending_ids',
          'run_generated', 'run_skipped', 'run_prompt_tokens', 'run_candidate_tokens',
          'run_total_tokens', 'run_trigger', 'run_actor'
        ]);
      }

      allow read: if canRunAiBatch();

      allow create, update: if canRunAiBatch()
        && hasOnlyAutomationFields()
        && withinFieldLimit(30);

      allow delete: if false;
    }

    // =========================================================================
    // [DSC] 강사 배정 변경 이력 (append-only — 강사 재등원율 등 분석용, 도입 이후만 누적)
    // class_settings.teacher는 현재값만 보존하므로, 변경 시점을 별도 기록한다.
    // =========================================================================
    match /class_teacher_history/{docId} {
      allow read: if isAuthorized();

      allow create: if isAuthorized()
        && request.resource.data.keys().hasOnly([
          'class_code', 'class_type', 'branch',
          'teacher', 'sub_teacher', 'prev_teacher', 'prev_sub_teacher',
          'changed_at', 'changed_by'
        ])
        && request.resource.data.class_code is string
        && request.resource.data.class_code.size() > 0
        && request.resource.data.changed_by is string
        && request.resource.data.changed_by.size() > 0;

      allow update, delete: if false;
    }

    // =========================================================================
    // [DSC] Class Next Homework (반별 다음숙제)
    // =========================================================================
    match /class_next_hw/{docId} {

      function hasOnlyAllowedClassNextHwFields() {
        return request.resource.data.keys().hasOnly([
          'class_code', 'date', 'domains',
          'updated_by', 'updated_at'
        ]);
      }

      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && hasOnlyAllowedClassNextHwFields()
        && withinFieldLimit(15);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DSC] Daily Checks (일일 체크)
    // =========================================================================
    match /daily_checks/{docId} {

      function hasOnlyAllowedDailyCheckFields() {
        return request.resource.data.keys().hasOnly([
          // 메타데이터
          'date', 'student_id', 'enrollment_index', 'class_code',
          'student_name', 'branch', 'updated_by', 'updated_at',
          // 출결
          'attendance', 'attendance_time', 'attendance_reason',
          // 숙제
          'hw_reading', 'hw_grammar', 'hw_practice', 'hw_listening',
          'hw_extra', 'hw_vocab', 'hw_idiom', 'hw_verb3',
          // 리뷰테스트
          'test_reading', 'test_grammar', 'test_practice', 'test_listening',
          // ISC
          'isc',
          // 부실 숙제 보완
          'review_reading', 'review_grammar', 'review_practice', 'review_listening',
          'review_extra', 'review_vocab', 'review_idiom', 'review_verb3',
          // 재시
          'retest_isc', 'retest_reading', 'retest_grammar', 'retest_practice',
          'retest_listening', 'retest_grading',
          // 다음 숙제
          'next_listening', 'next_summary', 'next_reading', 'next_grammar',
          'next_practice', 'next_listening2', 'next_extra',
          // 전달사항
          'note_class_to_study', 'note_to_parent',
          // 결석생 대응
          'absent_handler', 'absent_consultation',
          // LMS
          'lms_content'
        ]);
      }

      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && hasOnlyAllowedDailyCheckFields()
        && withinFieldLimit(50);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DSC] Postponed Tasks (연기/보강 작업)
    // =========================================================================
    match /postponed_tasks/{docId} {

      function hasOnlyAllowedPostponedFields() {
        return request.resource.data.keys().hasOnly([
          'student_id', 'student_name', 'original_date',
          'scheduled_date', 'scheduled_time', 'content', 'handler',
          'status', 'result',
          'created_by', 'created_at', 'updated_by', 'updated_at'
        ]);
      }

      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && hasOnlyAllowedPostponedFields()
        && withinFieldLimit(15);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DSC] Absence Records (결석생대장)
    // =========================================================================
    match /absence_records/{docId} {

      function hasOnlyAllowedAbsenceFields() {
        return request.resource.data.keys().hasOnly([
          'student_id', 'student_name', 'branch', 'class_code', 'absence_date',
          'consultation_done', 'consultation_note',
          'reason', 'reason_valid', 'resolution', 'settlement_memo',
          'makeup_date', 'makeup_time',
          'makeup_status', 'makeup_completed_by', 'makeup_completed_at',
          'reschedule_history',
          'marked_absent_by', 'marked_absent_at',
          'status', 'created_by', 'created_at', 'updated_by', 'updated_at'
        ]);
      }

      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && hasOnlyAllowedAbsenceFields()
        && request.resource.data.status is string
        && request.resource.data.status in ['open', 'done', 'closed']
        && withinFieldLimit(25);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DSC] Leave Requests (휴퇴원요청서)
    // =========================================================================
    match /leave_requests/{docId} {

      function hasOnlyAllowedLeaveRequestFields() {
        return request.resource.data.keys().hasOnly([
          'student_id', 'student_name', 'branch', 'class_codes',
          'request_type', 'leave_sub_type',
          'leave_start_date', 'leave_end_date', 'withdrawal_date',
          'student_phone', 'parent_phone_1',
          'consultation_note', 'status',
          'requested_by', 'requested_at',
          'approved_by', 'approved_at',
          'teacher_approved_by', 'teacher_approved_at',
          'return_date',
          'previous_status', 'created_at', 'updated_by', 'updated_at',
          // Cloud Function 연동 (재등원·복귀 반 선택 + 서버사이드 finalize)
          'target_class_code', 'target_semester',
          'finalized_at', 'finalize_error', 'finalize_attempts'
        ]);
      }

      // admin 필드(finalize_*)는 Cloud Function(admin SDK)만 쓸 수 있음 — 클라이언트 차단
      function notTouchingAdminFields() {
        let admin = ['finalized_at', 'finalize_error', 'finalize_attempts'];
        return resource == null
          || !request.resource.data.diff(resource.data).affectedKeys().hasAny(admin);
      }

      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && hasOnlyAllowedLeaveRequestFields()
        && request.resource.data.status is string
        && request.resource.data.status in ['requested', 'approved', 'rejected', 'cancelled']
        && withinFieldLimit(30)
        && notTouchingAdminFields();

      allow delete: if isAuthorized();
    }

    // 학생 기록(반성문·기타) — 일시 + 내용 + Storage 파일 첨부
    match /student_records/{docId} {

      function hasOnlyAllowedStudentRecordFields() {
        return request.resource.data.keys().hasOnly([
          'student_id', 'type', 'occurred_at', 'content', 'files', 'important',
          'created_at', 'updated_by', 'updated_at'
        ]);
      }

      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && hasOnlyAllowedStudentRecordFields()
        && request.resource.data.type is string
        && request.resource.data.type in ['reflection', 'etc']
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 5000
        && (!('important' in request.resource.data) || request.resource.data.important is bool)
        && withinFieldLimit(15);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DSC] Temp Attendance (임시출석)
    // =========================================================================
    match /temp_attendance/{docId} {
      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && request.resource.data.keys().hasOnly([
          'name', 'branch', 'school', 'level', 'grade',
          'student_phone', 'parent_phone_1', 'memo',
          'temp_date', 'temp_time', 'visit_status', 'temp_arrival',
          'created_at', 'created_by',
          'completed_by', 'completed_at',
          'updated_by', 'updated_at', 'edit_history',
          'arrival_status', 'cancel_reason',
          // 진단평가신청서(diagnostic_application) 동기화 경로가 부여하는 메타 필드
          'source', 'source_application_id', 'student_id', 'marketing_consent'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.branch is string
        && request.resource.data.branch.size() > 0
        && request.resource.data.school is string
        && request.resource.data.school.size() > 0
        && request.resource.data.level is string
        && request.resource.data.level.size() > 0
        && request.resource.data.grade is string
        && request.resource.data.grade.size() > 0
        && withinFieldLimit(25);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DSC] Teachers (선생님 목록 — 로그인 시 자동 등록)
    // =========================================================================
    match /teachers/{email} {
      allow read: if isAuthorized();

      allow create: if isAuthorized()
        && request.resource.data.keys().hasOnly([
          'email', 'display_name', 'photo_url', 'last_login',
          'updated_by', 'updated_at'
        ])
        && request.resource.data.email is string
        && withinFieldLimit(10);

      // update는 바뀐 키만 검사 — 스윕이 심은 homeroom_eligible·board_assignable가
      // 병합 결과에 있어도 통과하되, 클라이언트가 그 필드를 변경·자기부여하지 못하게 막는다.
      allow update: if isAuthorized()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'email', 'display_name', 'photo_url', 'last_login',
          'updated_by', 'updated_at'
        ])
        && request.resource.data.email is string;

      allow delete: if false;
    }

    // =========================================================================
    // [DSC] Semester Settings (학기 시작일 설정)
    // =========================================================================
    match /semester_settings/{semester} {
      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && request.resource.data.keys().hasOnly(['start_date'])
        && withinFieldLimit(5);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [DB] Contacts (과거 연락처)
    // =========================================================================
    match /contacts/{docId} {
      allow read: if isAuthorized();

      allow create, update: if isAuthorized()
        && request.resource.data.keys().hasOnly([
          'name', 'level', 'school', 'grade',
          'student_phone', 'parent_phone_1', 'parent_phone_2',
          'guardian_name_1', 'guardian_name_2',
          'first_registered', 'status_history',
          'created_at', 'updated_at'
        ])
        && withinFieldLimit(15);

      allow delete: if isAuthorized();
    }

    // =========================================================================
    // [Director] 사용자/역할 (uid 기반)
    // =========================================================================
    match /HR_users/{uid} {
      function isSafeShortTermSelfCreate() {
        return request.resource.data.role == 'shortterm'
          && isImpact7VerifiedEmail()
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.keys().hasOnly(['email', 'name', 'role', 'permissions', 'assignedBuildings'])
          && request.resource.data.permissions is map
          && request.resource.data.assignedBuildings is list
          // 신규 권한 카탈로그 키의 자가 주입 차단 — 자기생성은 기존 18키 외 어떤 키도 쓸 수 없다
          && request.resource.data.permissions.keys().hasOnly(['canViewPopulationStats', 'canViewClassCounts', 'canViewDashboard', 'canViewStudents', 'canEditStudents', 'canViewStudentPrivateInfo', 'canViewAttendance', 'canEditAttendance', 'canViewConsultations', 'canEditConsultations', 'canViewPayments', 'canManagePayments', 'canViewSalary', 'canManagePayroll', 'canManageEmployees', 'canManagePermissions', 'canSignContract', 'canSendEmail'])
          && request.resource.data.permissions.get('canViewPopulationStats', false) == false
          && request.resource.data.permissions.get('canViewClassCounts', false) == false
          && request.resource.data.permissions.get('canViewDashboard', false) == false
          && request.resource.data.permissions.get('canViewStudents', false) == false
          && request.resource.data.permissions.get('canEditStudents', false) == false
          && request.resource.data.permissions.get('canViewStudentPrivateInfo', false) == false
          && request.resource.data.permissions.get('canViewAttendance', false) == false
          && request.resource.data.permissions.get('canEditAttendance', false) == false
          && request.resource.data.permissions.get('canViewConsultations', false) == false
          && request.resource.data.permissions.get('canEditConsultations', false) == false
          && request.resource.data.permissions.get('canViewPayments', false) == false
          && request.resource.data.permissions.get('canManagePayments', false) == false
          && request.resource.data.permissions.get('canViewSalary', false) == false
          && request.resource.data.permissions.get('canManagePayroll', false) == false
          && request.resource.data.permissions.get('canManageEmployees', false) == false
          && request.resource.data.permissions.get('canManagePermissions', false) == false
          && request.resource.data.permissions.get('canSendEmail', false) == false;
      }

      function canUpdateNonOwnerUser() {
        return canManagePermissions()
          && request.auth.uid != uid
          && !(resource.data.role in ['owner', 'principal'])
          && request.resource.data.role in ['director', 'manager', 'teacher', 'payment', 'staff', 'shortterm']
          && request.resource.data.keys().hasOnly(['email', 'name', 'role', 'permissions', 'assignedBuildings'])
          && request.resource.data.permissions is map
          && request.resource.data.permissions.get('canManagePermissions', false) == resource.data.permissions.get('canManagePermissions', false)
          // 민감 지표(인원현황) 권한은 오너/원장만 부여·회수 가능 — 위임받은 권한 관리자는 변경 불가
          && (isDirector()
              || (request.resource.data.permissions.get('canViewPopulationStats', false) == resource.data.permissions.get('canViewPopulationStats', false)
                  && request.resource.data.permissions.get('canViewClassCounts', false) == resource.data.permissions.get('canViewClassCounts', false)));
      }

      allow read: if isLoggedIn() && request.auth.uid == uid;
      allow read: if isDirector();
      allow read: if canManagePermissions();
      // Allow self-create for bootstrap (only if doc doesn't exist yet)
      allow create: if isLoggedIn()
        && request.auth.uid == uid
        && !exists(/databases/$(database)/documents/HR_users/$(uid))
        && (
          isSafeShortTermSelfCreate()
          || (uid == 'pdeLLg8tBReyyBLr7HoHnCxWz6Z2' && request.resource.data.role in ['owner', 'principal'])
        );
      allow update: if isOwner() || canUpdateNonOwnerUser();
      allow delete: if isOwner();
    }

    // =========================================================================
    // [Director] Entities / Buildings / Teams
    // =========================================================================
    // read를 isLoggedIn()으로 열면 임의 Google 계정(비 impact7)도 법인·조직 정보를 읽는다(H-1).
    // 단기직원은 외부 도메인 계정이라 isShortTerm()으로 병행 허용.
    match /entities/{id} { allow read: if isImpact7VerifiedEmail() || isShortTerm(); allow write: if isDirector(); }
    match /buildings/{id} { allow read: if isImpact7VerifiedEmail() || isShortTerm(); allow write: if isDirector(); }
    match /teams/{id} { allow read: if isImpact7VerifiedEmail() || isShortTerm(); allow write: if isDirector(); }

    // =========================================================================
    // [Director] Onboarding Tokens
    // =========================================================================
    match /onboardingTokens/{tokenId} {
      // director/staff: 전체 읽기·쓰기
      allow read, write: if isDirector() || isStaff();

      // 비인증 토큰 검증 read는 getHrPublicToken callable로 이전(G03). 완료 처리(update)만 허용.
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'staffId'])
        && request.resource.data.status == 'completed'
        && resource.data.status == 'pending'
        && resource.data.expiresAt > request.time;

      allow create, delete: if isDirector() || isStaff();
    }

    // =========================================================================
    // [Director] Contract Signing Tokens
    // =========================================================================
    match /contractSigningTokens/{tokenId} {
      allow read, write: if isDirector() || isStaff();

      // 비인증 토큰 검증 read는 getHrPublicToken callable로 이전(G03). 서명 완료(update)만 허용.
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status'])
        && request.resource.data.status == 'signed'
        && resource.data.status == 'pending'
        && resource.data.expiresAt > request.time;

      allow create, delete: if isDirector() || isStaff();
    }

    // =========================================================================
    // [Director] Salary Notification Tokens (급여 통보서)
    // =========================================================================
    match /salaryAgreementTokens/{tokenId} {
      allow read, write: if isDirector() || isStaff();

      // 비인증 토큰 검증 read는 getHrPublicToken callable로 이전(G03). 서명 완료(update)만 허용.
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status'])
        && request.resource.data.status == 'signed'
        && resource.data.status == 'pending'
        && resource.data.expiresAt > request.time;

      allow create, delete: if isDirector() || isStaff();
    }

    // =========================================================================
    // [Director] Assignments (root-level)
    // =========================================================================
    match /assignments/{id} {
      allow read: if isImpact7VerifiedEmail() || isShortTerm();
      allow write: if isDirector();
    }

    // =========================================================================
    // [Director] 단기 인원
    // =========================================================================
    match /shortTermStaff/{docId} {
      // 레거시 단기 컬렉션(통합 staff로 마이그레이션됨). manager도 전체 열람(staff와 일관).
      // shortterm 역할 허용 제거(2026-07-05 감사): 계정 미발급 상태에서 동료 PII(주민번호·계좌)
      // 수평 노출 표면이었음. 역할 재도입 시 본인 문서 스코프(ownerUid)로 설계할 것.
      allow read: if isDirector() || isManager();
      allow write: if isDirector();

      // 비인증: 토큰 기반 등록 (필수 필드 + hasOnly + 토큰 검증)
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'email', 'residentNumber', 'address', 'bank', 'accountNumber', 'accountHolder', 'createdAt', 'tokenId'])
        && request.resource.data.keys().hasOnly(['name', 'phone', 'email', 'residentNumber', 'address', 'bank', 'accountNumber', 'accountHolder', 'createdAt', 'tokenId', 'status'])
        && request.resource.data.name is string
        && request.resource.data.phone is string
        && hrOnboardingTokenValid(/databases/$(database)/documents/shortTermTokens/$(request.resource.data.tokenId));

      match /contracts/{contractId} {
        allow read: if isDirector();
        allow write: if isDirector();
      }
    }

    // =========================================================================
    // [Director] 단기 온보딩 토큰
    // =========================================================================
    match /shortTermTokens/{tokenId} {
      allow read, write: if isDirector();

      // 비인증 토큰 검증 read는 getHrPublicToken callable로 이전(G03). 완료 처리(update)만 허용.
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'personId'])
        && request.resource.data.status == 'completed'
        && resource.data.status == 'pending'
        && resource.data.expiresAt > request.time;

      allow create, delete: if isDirector();
    }

    // [Director] Staff + 서브컬렉션
    // =========================================================================
    match /staff/{staffId} {
      // PII 보호: 전 직원 신원 정보(주민번호·계좌·연락처)를 director+manager만 전체 열람.
      // shortterm 단기부서 read 제거(2026-07-05 감사): 계정 미발급 상태의 동료 PII 수평 노출
      // 표면이었음. 역할 재도입 시 본인 문서 스코프(ownerUid)로 설계할 것.
      allow read: if isDirector() || isManager();
      allow write: if isDirector() || isManager();

      // 온보딩: 비인증 사용자가 유효한 토큰으로 staff 문서 생성 (통합: 교사/행정/단기 3종 토큰)
      // hasOnly = 교사필드 ∪ {position(행정)} ∪ {department, affiliation, interviewDate, resignationDate} ∪ {phoneKey, englishName(키오스크 매칭/표시, 무권한)}.
      // 권한 부여 필드(role 등)는 목록에 없으므로 온보딩 create로 권한 주입 불가.
      allow create: if request.resource.data.status == 'onboarding'
        && request.resource.data.keys().hasAll(['tokenId'])
        && request.resource.data.keys().hasOnly(['name', 'phone', 'email', 'residentNumber', 'birthDate', 'address', 'subject', 'bankInfo', 'taxInfo', 'documents', 'staffType', 'status', 'joinDate', 'onboardingCompletedAt', 'memo', 'tokenId', 'position', 'department', 'affiliation', 'interviewDate', 'resignationDate', 'phoneKey', 'englishName'])
        && (
          hrOnboardingTokenValid(/databases/$(database)/documents/onboardingTokens/$(request.resource.data.tokenId))
          || hrOnboardingTokenValid(/databases/$(database)/documents/employeeOnboardingTokens/$(request.resource.data.tokenId))
          || hrOnboardingTokenValid(/databases/$(database)/documents/shortTermTokens/$(request.resource.data.tokenId))
        );

      // 비인증 staff 읽기는 getHrPublicToken callable로 이전(G03) — 공개 get 제거.

      match /contracts/{contractId} {
        allow read: if isDirector() ||
          (isStaff() && resource.data.assignedTo == request.auth.uid);
        allow write: if isDirector();

        // 비인증 계약서 읽기·서명은 모두 callable로 이전. read=getHrPublicToken(G03),
        // 서명 write=submitContractSignature·submitSalaryAgreementSignature(Admin SDK, 토큰 검증·
        // raster 서명·자기 서명만 write). 익명 update는 rules가 signatures 중첩 내용을 검증 못 해
        // signatures.director 덮어쓰기·SVG data-URL(저장형 XSS) 주입이 가능했으므로 제거한다.
        // director 서명·PDF 수리 등 관리자 write는 위 `allow write: if isDirector()`가 계속 커버.
      }

      match /assignments/{id} {
        allow read: if isImpact7VerifiedEmail() || isShortTerm();
        allow write: if isDirector();
      }

      match /documents/{docId} {
        allow read: if isDirector() ||
          (isStaff() && staffId == request.auth.uid);
        allow write: if isDirector();
      }

      match /performanceNotes/{noteId} {
        allow read, write: if isDirector();
      }
    }

    // =========================================================================
    // [Director] collectionGroup 쿼리용 — contracts
    // =========================================================================
    match /{path=**}/contracts/{contractId} {
      allow read: if isDirector() ||
        (isStaff() && resource.data.assignedTo == request.auth.uid);
    }

    // =========================================================================
    // [Director] collectionGroup 쿼리용 — documents (서류함)
    // =========================================================================
    match /{path=**}/documents/{docId} {
      allow read: if isDirector();
    }

    // =========================================================================
    // [Director] Contract Templates
    // =========================================================================
    match /contractTemplates/{id} {
      // 근로계약서 템플릿(법적 조항) — 임의 Google 계정 열람 차단(H-1), 단기직원 서명 흐름은 허용
      allow read: if isImpact7VerifiedEmail() || isShortTerm();
      allow write: if isDirector();
    }

    // =========================================================================
    // [Director] HR 설정 (역할별 권한 템플릿 등 — 권한설정 화면 전용)
    // =========================================================================
    // 실제 권한 강제는 HR_users.permissions·staff.permissions(실체화본)로 이뤄지고,
    // 이 컬렉션은 편집용 템플릿 저장소다. 민감 지표 제한은 HR_users update 규칙이 계속 강제.
    match /HR_config/{docId} {
      allow read, write: if isDirector() || canManagePermissions();
    }

    // =========================================================================
    // [Director] Payroll
    // =========================================================================
    match /payroll/{yearMonth}/staff/{staffId} {
      allow read, write: if isDirector();
    }

    // =========================================================================
    // [Director] Expenses / Vendors / Tax Reports
    // =========================================================================
    match /expenses/{id} { allow read, write: if isDirector(); }
    match /vendors/{id} { allow read, write: if isDirector(); }
    match /taxReports/{id} { allow read, write: if isDirector(); }

    // =========================================================================
    // [Director] Audit Log
    // =========================================================================
    match /auditLog/{id} {
      allow read: if isDirector();
      // isLoggedIn() 개방은 임의 Google 계정의 허위 감사기록 주입을 허용했음(H-1)
      allow create: if isImpact7VerifiedEmail() || isShortTerm();
      allow update, delete: if false;
    }

    // =========================================================================
    // [Director] Employee Onboarding Tokens
    // =========================================================================
    match /employeeOnboardingTokens/{tokenId} {
      allow read, write: if isDirector() || isStaff();
      // 비인증 토큰 검증 read는 getHrPublicToken callable로 이전(G03). 완료 처리(update)만 허용.
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'staffId'])
        && request.resource.data.status == 'completed'
        && resource.data.status == 'pending'
        && resource.data.expiresAt > request.time;
      allow create, delete: if isDirector() || isStaff();
    }

    // =========================================================================
    // [Director] Employee Contract Signing Tokens
    // =========================================================================
    match /employeeContractSigningTokens/{tokenId} {
      allow read, write: if isDirector() || isStaff();
      // 비인증 토큰 검증 read는 getHrPublicToken callable로 이전(G03). 서명 완료(update)만 허용.
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status'])
        && request.resource.data.status == 'signed'
        && resource.data.status == 'pending'
        && resource.data.expiresAt > request.time;
      allow create, delete: if isDirector() || isStaff();
    }

    // =========================================================================
    // [Director] Employees + 서브컬렉션
    // =========================================================================
    match /employees/{employeeId} {
      // 레거시 컬렉션(통합 staff로 마이그레이션됨, 클라 read 없음). staff와 동일하게 PII read 차단:
      // director+manager만. isLoggedIn() 개방은 staff 잠금(#5)을 우회하는 동일 PII 노출이라 닫는다.
      allow read: if isDirector() || isManager();
      allow write: if isDirector();
      allow create: if request.resource.data.status == 'onboarding'
        && request.resource.data.keys().hasAll(['tokenId'])
        && request.resource.data.keys().hasOnly(['name', 'phone', 'email', 'residentNumber', 'birthDate', 'address', 'position', 'bankInfo', 'taxInfo', 'documents', 'status', 'joinDate', 'onboardingCompletedAt', 'memo', 'tokenId'])
        && exists(/databases/$(database)/documents/employeeOnboardingTokens/$(request.resource.data.tokenId))
        && get(/databases/$(database)/documents/employeeOnboardingTokens/$(request.resource.data.tokenId)).data.status == 'pending'
        && get(/databases/$(database)/documents/employeeOnboardingTokens/$(request.resource.data.tokenId)).data.expiresAt > request.time;
      // 비인증 employee 읽기는 getHrPublicToken callable로 이전(G03) — 공개 get 제거.

      match /contracts/{contractId} {
        allow read: if isDirector() ||
          (isStaff() && resource.data.assignedTo == request.auth.uid);
        allow write: if isDirector();
        // 레거시 컬렉션(통합 staff로 마이그레이션) — 비인증 계약 read·서명 write는 모두 callable로
        // 이전됨(위 staff/contracts와 동일). 익명 서명 update는 signatures 중첩 검증 불가로 인한
        // director 서명 덮어쓰기·SVG XSS 위험이 있어 제거. 관리자 write는 isDirector가 커버.
      }

      match /performanceNotes/{noteId} {
        allow read, write: if isDirector();
      }
    }

    // =========================================================================
    // [Exam] 학부 설정
    // =========================================================================
    match /departments/{deptId} {
      allow read: if isAuthorized();
      // 설정성 컬렉션 — exam 프론트 nav/페이지 게이트(OwnerOnly)와 짝
      allow write: if isExamOwner();
    }

    // =========================================================================
    // [Exam] 시험 종류
    // =========================================================================
    match /examTypes/{typeId} {
      allow read: if isAuthorized();
      // 설정성 컬렉션 — exam 프론트 nav/페이지 게이트(OwnerOnly)와 짝
      allow write: if isExamOwner();
    }

    // =========================================================================
    // [Exam] 시험
    // =========================================================================
    match /exams/{examId} {
      allow read: if isAuthorized();
      allow create, update, delete: if isExamMember();
    }

    // =========================================================================
    // [Exam] 정답표 — exams 와 분리된 재사용 가능한 엔티티
    // =========================================================================
    match /answer_keys/{keyId} {
      allow read: if isAuthorized();
      // write는 서버(Admin SDK)만 — client write 경로 0개 확인(2026-07-05), 심층 방어로 차단
      allow create, update, delete: if false;
    }

    // =========================================================================
    // [Exam] 채점 결과
    // =========================================================================
    match /results/{examId} {
      allow read: if isAuthorized();
      // 부모 문서는 client write 경로 없음 — write는 students 서브컬렉션만
      allow write: if false;

      match /students/{studentId} {
        allow read: if isAuthorized();
        // OCR 채점 저장 — teacher가 client SDK로 직접 write. owner 전용화 금지(채점 마비)
        allow write: if isExamMember();
      }
    }

    // =========================================================================
    // [Exam] 외부 성적 (내신/모의고사)
    // =========================================================================
    match /external_score_events/{eventId} {
      allow read: if isAuthorized();
      allow create, update, delete: if isExamMember();

      match /students/{studentId} {
        allow read: if isAuthorized();
        allow write: if isExamMember();
      }
    }

    // =========================================================================
    // [Exam] 알림
    // =========================================================================
    match /exam_notifications/{notifId} {
      allow read: if isAuthorized();
      allow create: if isExamMember();
    }

    // =========================================================================
    // [Exam] 템플릿
    // =========================================================================
    match /exam_templates/{templateId} {
      allow read: if isAuthorized();
      // write는 서버(Admin SDK)만 — client write 경로 0개 확인(2026-07-05), 심층 방어로 차단
      allow write: if false;
    }

    // =========================================================================
    // [Exam] 비동기 검수/OCR job — 워커(Admin SDK)가 write, 생성자만 read
    // =========================================================================
    match /exam_review_jobs/{jobId} {
      allow read: if isAuthorized() && resource.data.createdBy == request.auth.uid;
      allow write: if false;
    }

    // =========================================================================
    // [Exam] 수능인덱스 묶음
    // =========================================================================
    match /exam_sets/{setId} {
      allow read: if isAuthorized();
      allow create, delete: if isExamMember();
      allow update: if isExamMember()
        && (isExamOwner()
          || !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'attendanceGeneration', 'attendanceCleanupGenerations'
          ]));
    }

    // =========================================================================
    // [Exam] 내신분석자료
    // =========================================================================
    match /exam_analyses/{id} {
      // 외부 도메인 차단 — request.auth != null이 아닌 도메인 검증(N-01).
      allow read: if isAuthorized();
      allow create: if isExamMember()
                      && request.resource.data.createdBy == request.auth.uid;
      // 모더레이션은 owner 역할 — 구 admin 커스텀 클레임은 프로비저닝 경로가 없는 죽은 분기였음
      allow update, delete: if isExamMember()
                              && (resource.data.createdBy == request.auth.uid
                                  || isExamOwner());
    }

    // =========================================================================
    // [공통] 감사 로그
    // =========================================================================
    match /audit_logs/{logId} {
      allow create: if isAuthorized();
      allow read: if isAuthorized();
      allow update, delete: if false;
    }

    // [공통] 학생 성적 요약(student_scores) — 서버 Cloud Function(admin)만 갱신. F-11.
    match /student_scores/{studentId} {
      allow read: if isAuthorized();
      allow write: if false;
    }

    // =========================================================================
    // [공통] 상담 데이터
    // =========================================================================
    match /consultations/{cid} {
      allow read: if isAuthorized();

      allow create: if isAuthorized()
        && request.resource.data.teacher_id == request.auth.uid
        && request.resource.data.ai_processed == false
        && request.resource.data.keys().hasAll(['student_id', 'teacher_id', 'date', 'consultation_type', 'text', 'ai_processed', 'created_at', 'updated_at']);

      // 본인 작성 + 24h 이내 update만. ai_processed/ai_processed_at은 admin SDK만 변경 가능
      allow update: if isAuthorized()
        && resource.data.teacher_id == request.auth.uid
        && resource.data.created_at > request.time - duration.value(24, 'h')
        && !(request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['ai_processed', 'ai_processed_at', 'teacher_id', 'created_at']));

      allow delete: if false;
    }

    // =========================================================================
    // [공통] 상담 AI 산출물 (서버 전용 쓰기, 클라이언트 읽기만)
    // =========================================================================
    match /consultation_summaries/{studentId} {
      allow read: if isAuthorized();
      allow write: if false;
    }

    match /consultation_briefings/{studentId} {
      allow read: if isAuthorized();
      allow write: if false;
    }

    match /consultation_trends/{periodKey} {
      allow read: if isAuthorized();
      allow write: if false;
    }

    // 학생 종합 상태 AI 요약 (서버 전용 쓰기, 클라이언트 읽기만)
    match /student_status_summaries/{studentId} {
      allow read: if isAuthorized();
      allow write: if false;
    }

    // 상담 고정(pin) — 24h window 없는 별도 컬렉션 (consultations는 안 건드림)
    match /consultation_pins/{cid} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized()
        && request.resource.data.teacher_id == request.auth.uid;
      allow delete: if isAuthorized()
        && resource.data.teacher_id == request.auth.uid;
    }

    // 공유 백엔드 로그 — 서버(Functions Admin SDK)만, 클라 접근 금지
    match /notification_logs/{logId} {
      allow read, write: if false;
    }

    // 결제 기록 — 서버(Functions Admin SDK)만, 멱등키=docId
    match /payment_records/{key} {
      allow read, write: if false;
    }

    // === DSC 메시지 발송 — 서버(Functions Admin SDK)만 쓰기 ===

    // 출결 체크인 이벤트/멱등 앵커 — 서버 전용, 클라 접근 전면 차단
    match /attendance_checkins/{id} {
      allow read, write: if false;
    }

    // 메시지 발송 큐 — 서버 전용(발송용 평문 번호 보유). 대시보드는 집계 callable 경유(T10).
    match /message_queue/{id} {
      allow read, write: if false;
    }

    // 태블릿 출결 이벤트 로그 — 쓰기는 서버(Admin SDK)·tabletCheckin callable 전용; 읽기는 직원 인증 허용.
    match /attendance_events/{docId} {
      allow read: if isAuthorized();
      allow write: if false;
    }

    // 키오스크 단말 정책(departure_policy) — 정책은 서버가 deviceId로 조회·적용
    match /kiosk_devices/{deviceId} {
      allow read, write: if false;
    }

    // 키오스크 전역 설정(조회 PIN·잠금 상태) — 서버 전용. PIN이 클라에 노출되지 않게 한다.
    match /kiosk_settings/{docId} {
      allow read, write: if false;
    }

    // 직원 근태 설정 — 매니저 이상 read/write. 서버 callable도 Admin SDK로 우회.
    match /settings/{docId} {
      allow read: if isDirector() || isManager();
      allow write: if isDirector() || isManager();
    }

    // 직원 출퇴근 기록 — 서버(Admin SDK)만 기록, 조회는 원장급(HR 월별 조회).
    match /staff_attendance/{docId} {
      allow read: if isDirector() || isManager();
      allow write: if false;
    }

    // 메시지 발송 로그 — 대시보드 read 허용, 쓰기는 Admin SDK 전용
    match /message_logs/{id} {
      allow read: if isAuthorized();
      allow write: if false;
    }

    // 메시지 공용 설정(학원 꼬리말·채널 가입 안내 문구) — 전 직원 공유. 개인정보 없는 문안 전용.
    match /message_settings/{id} {
      allow read: if isAuthorized();
      allow write: if isAuthorized()
        && request.resource.data.keys().hasOnly(['sms_footer', 'channel_invite', 'updated_by', 'updated_at'])
        && request.resource.data.get('sms_footer', '') is string && request.resource.data.get('sms_footer', '').size() <= 300
        && request.resource.data.get('channel_invite', '') is string && request.resource.data.get('channel_invite', '').size() <= 300;
    }

    // 메시지 템플릿(자주 쓰는 문구) — 전 직원 공유 저장소. 개인정보 없는 문안만 담는다.
    match /message_templates/{id} {
      allow read, delete: if isAuthorized();
      allow create, update: if isAuthorized()
        && request.resource.data.keys().hasOnly(['title', 'content', 'updated_by', 'updated_at'])
        && request.resource.data.title is string && request.resource.data.title.size() <= 100
        && request.resource.data.content is string && request.resource.data.content.size() <= 5000;
    }

    // 홍보(광고) 캠페인 — 서버(createPromoCampaign callable) 전용 쓰기.
    // 광고 발송 이력·대상은 민감하므로 read는 원장(isDirector)만.
    match /promo_campaigns/{id} {
      allow read: if isDirector();
      allow write: if false;
    }

    // =========================================================================
    // 기본 거부: 위에 매칭되지 않는 모든 경로 차단
    // =========================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
